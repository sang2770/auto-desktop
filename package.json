{
  "name": "auto-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop automation tool for scheduled streaming workflows.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/run-electron.cjs",
    "build": "vite build",
    "build:app": "vite build",
    "build:runner:win": "node scripts/build-runner-win.cjs",
    "dist:win": "npm run build:app && npm run build:runner:win && electron-builder --win nsis",
    "dist:win:portable": "npm run build:app && npm run build:runner:win && electron-builder --win portable",
    "pack:win": "npm run build:app && npm run build:runner:win && electron-builder --win dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^31.7.2",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.autodesktop.app",
    "productName": "Auto Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "workflows/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "build/runner/win/automation_runner.exe",
        "to": "runner/automation_runner.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Auto-Desktop-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Auto-Desktop-Portable-${version}.${ext}"
    }
  }
}
